DEBUG=True
SECRET_KEY=replace-me-with-a-secure-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
THROTTLE_USER_RATE=120/minute
THROTTLE_ANON_RATE=20/minute
THROTTLE_AUTH_RATE=15/minute
THROTTLE_SUPPORT_REPLY_RATE=30/minute
THROTTLE_PRIVACY_RATE=10/minute
THROTTLE_CROP_IMAGE_GENERATION_RATE=10/hour
ENCRYPTION_KEY=replace-with-fernet-key
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/agrosmart
DB_CONN_MAX_AGE=600

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_MAX_CONNECTIONS=200

# ── Cache TTLs (seconds) ──────────────────────────────
CACHE_DEFAULT_TTL=300
CACHE_TTL_DASHBOARD=60
CACHE_TTL_ALERTS=120
CACHE_TTL_GUIDES=300
CACHE_TTL_NOTIFICATIONS=300
CACHE_TTL_CROPS=3600
CACHE_TTL_CATEGORIES=3600
CACHE_TTL_QUICK_REPLIES=3600

# ── Gunicorn ──────────────────────────────────────────
GUNICORN_WORKERS=9
GUNICORN_THREADS=4
GUNICORN_WORKER_CLASS=gthread
GUNICORN_TIMEOUT=120
GUNICORN_MAX_REQUESTS=1000
GUNICORN_LOG_LEVEL=info

# ── AI Image Generation ───────────────────────────────
# Choose provider: openai (default) or huggingface
IMAGE_GENERATION_PROVIDER=openai

# OpenAI DALL-E 3 API key – get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-with-your-openai-api-key

# Hugging Face token – only needed if IMAGE_GENERATION_PROVIDER=huggingface
# Get one at https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=hf_replace-with-your-huggingface-token